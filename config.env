REPO_ROOT=/work

WORKFLOW_OUTPUT_DIR=/work/demo/output

TRAIN_JSON=/work/demo/data/queries.jsonl

TOP_K=100
RECALL_KS=10,50,100

BM25_INDEX_PATH=/work/demo/indexes/bm25
DENSE_INDEX_DIR=/work/demo/indexes/dense

BM25_THREADS=2
BM25_SAVE_RUNS=1

DENSE_DEVICE=cpu
DENSE_BATCH_SIZE=32

HYBRID_MODE=default
HYBRID_JOBS=2

DOCS_JSONL=/work/demo/data/docs.jsonl
RERANK_CANDIDATE_LIMIT=50
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MODEL_DEVICE=cpu
RERANK_MODEL_BATCH=8
RERANK_MODEL_MAX_LENGTH=512

RUN_BASELINE=1
RUN_SNIPPET_RRF=0
RUN_GENERATION_BASELINE=0
RUN_GENERATION_SNIPPET=0
